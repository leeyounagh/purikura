{
  "expo": {
    "name": "purisnap",
    "slug": "purikura",
    "version": "1.2.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "purisnap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.leesuyoen.purisnapapp",
      "supportsTablet": true,
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "permissions": [
        "com.google.android.gms.permission.AD_ID"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffdce6"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.leesuyoen.purisnapapp",
      "runtimeVersion": "1.2.5",
      "versionCode": 14
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffdce6"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5067038499285963~4579815970",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      "expo-localization",
      "./plugins/withAndroidAdIdPermission.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1abe62b0-fe00-4bf2-8873-ee86a43f822a"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/1abe62b0-fe00-4bf2-8873-ee86a43f822a"
    },
    "owner": "leesuyoen"
  }
}
